{
  "name": "api-tcc-pro",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node bin/server.js",
    "build": "eslint . && prettier --write . && NODE_ENV=production node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint . --fix --config eslint.config.cjs",
    "start:onContainer": "node bin/server.js",
    "format": "prettier --write .",
    "mongo": "docker container rm test-mongo -f && docker run -d -p 27017:27017 -p 28017:28017 --name test-mongo -e AUTH=no mongo:latest;",
    "postgres": "docker container rm test -f && docker run --name test -e POSTGRES_USER=test -e POSTGRES_PASSWORD=test -p 5434:5432 -d postgres;",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#repositories/*": [
      "./app/repositories/*.js"
    ],
    "#interfaces/*": [
      "./app/interfaces/*.js"
    ],
    "#enum/*": [
      "./app/enum/*.js"
    ],
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#tests/*": "./tests/*.js",
    "#config/*": "./config/*.js",
    "#commands/*": "./commands/*.js",
    "#swagger/*": "./app/swagger/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.7.0",
    "@adonisjs/eslint-config": "^1.3.0",
    "@adonisjs/prettier-config": "^1.3.0",
    "@adonisjs/tsconfig": "^1.3.0",
    "@eslint/eslintrc": "^2.1.4",
    "@japa/api-client": "^2.0.3",
    "@japa/assert": "^3.0.0",
    "@japa/plugin-adonisjs": "^3.0.1",
    "@japa/runner": "^3.1.4",
    "@swc/core": "^1.6.5",
    "@types/crypto-js": "^4.2.2",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^5.1.2",
    "hot-hook": "^0.2.6",
    "pino-pretty": "^11.2.1",
    "prettier": "^3.3.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.4"
  },
  "dependencies": {
    "@adonisjs/core": "^6.12.1",
    "@adonisjs/cors": "^2.2.1",
    "@adonisjs/lucid": "^21.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@vinejs/vine": "^2.1.0",
    "adonisjs-scheduler": "^2.6.4",
    "apple-signin-auth": "^2.0.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "google-auth-library": "^10.4.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.4.4",
    "node-cron": "^4.2.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-dist": "^4.14.0",
    "uuid": "^10.0.0",
    "uuidv4": "^6.2.13"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "eslintConfig": {
    "extends": "@adonisjs/eslint-config/app"
  },
  "prettier": "@adonisjs/prettier-config",
  "packageManager": "yarn@1.22.17+sha512.1f4a76e35057687d1437d21e1fffd14fcdad9793df36b695a52a44a16f844fb966a29342eb5799f80f880ef53c14ce86a39bf1d7ad929dc0cbf09d598d106b89",
  "overrides": {
    "openapi-types": "^12.1.3"
  }
}
