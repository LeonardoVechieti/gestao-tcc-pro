VITE_API_URL=http://localhost:3003

# 'true' usa a API real; qualquer outro valor (false, 0, ausente) usa os
# dados fictícios em src/assets/mocks/.
VITE_BACKEND_ACTIVE=false

# E-mail do aluno "logado" enquanto não existe autenticação de verdade.
# Se o backend não tiver nenhum aluno com esse e-mail, as telas caem no
# fallback de dados ficticios.
VITE_DEV_ALUNO_EMAIL=aluno@aluno.com
VITE_DEV_ALUNO_SENHA=123456
